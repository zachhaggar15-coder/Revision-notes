# Use your public production URL on Vercel so canonical URLs, robots.txt, and sitemap.xml are correct.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=hello@coursemind.app

# openai or anthropic. If omitted, CourseMind uses the first configured provider.
AI_PROVIDER=openai
AI_REQUEST_TIMEOUT_MS=45000
AI_RETRY_COUNT=1

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
